---
import "../styles/global.css";
import { sitePath } from "../lib/paths";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "作品、笔记和长期积累。" } = Astro.props;
const pageTitle = title === "个人网站" ? title : `${title} - 个人网站`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap topbar">
        <a class="brand" href={sitePath()}>个人网站</a>
        <nav aria-label="主导航">
          <a href={sitePath("projects/")}>Projects</a>
          <a href={sitePath("notes/")}>Notes</a>
          <a href={sitePath("about/")}>About</a>
        </nav>
      </div>
    </header>
    <main class="wrap">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="wrap">Built with Astro. Hosted on GitHub Pages.</div>
    </footer>
  </body>
</html>
